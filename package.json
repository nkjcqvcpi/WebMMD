{
  "name": "webmmd-workspace",
  "version": "0.1.1",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "description": "WebMMD — PMX-only MikuMikuDance model viewer targeting Safari 26 & WebGPU",
  "scripts": {
    "prepare": "pnpm build:wasm",
    "build:wasm": "node scripts/build-wasm.mjs",
    "dev": "pnpm --filter web-app dev",
    "build": "pnpm build:wasm && pnpm -r --filter \"!webmmd-workspace\" build",
    "test": "vitest run && cargo test",
    "test:coverage": "vitest run --coverage && cargo llvm-cov",
    "test:safari": "node scripts/run-safari-tests.mjs",
    "lint": "eslint . && cargo clippy --workspace --all-targets --all-features -- -D warnings",
    "format": "prettier --write . && cargo fmt",
    "format:check": "prettier --check . && cargo fmt --check",
    "fixtures:prepare": "node scripts/prepare-test-fixtures.mjs",
    "verify": "pnpm format:check && pnpm lint && pnpm test && pnpm build && pnpm test:safari"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.5",
    "@webgpu/types": "^0.1.44",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "selenium-webdriver": "^4.46.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "fflate": "^0.8.3"
  }
}
